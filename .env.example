# Copy this file to .env and fill in your keys.
# Get a free Gemini API key here: https://aistudio.google.com/app/apikey

GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: model overrides.
# Free tier: Flash and Flash-Lite have generous limits; Pro is ~50 req/day.
# Defaults below stay within the free tier comfortably.
GEMINI_FAST_MODEL=gemini-2.5-flash-lite
GEMINI_POWERFUL_MODEL=gemini-2.5-flash

# Optional: local model via Ollama (leave empty to disable)
# Install: https://ollama.com  -> then `ollama pull llama3.2`
OLLAMA_MODEL=
OLLAMA_HOST=http://localhost:11434

# Embedding model (runs locally, no API needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
